# ============================================================
#  VallorSoft — Környezeti változók sablon
#  Másold .env néven és töltsd ki a valódi értékekkel.
#  A valódi .env GITIGNORE-olt — soha ne commitold a titkokat!
# ============================================================

# ----- Alap -----
DATABASE_URL=postgres://user:password@host:5432/dbname
SESSION_SECRET=valami-hosszu-veletlen-titok
NODE_ENV=production
PORT=3000
APP_URL=https://example.com

# Integrációs kulcsok titkosításához (32 byte, hex vagy base64)
# Generálás: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTEGRATION_ENC_KEY=

# ----- Web Push (VAPID) -----
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@example.com

# ----- E-mail (Brevo) -----
BREVO_API_KEY=
BREVO_SENDER=noreply@example.com
MAIL_USER=noreply@example.com

# ----- Firebase -----
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_DB_URL=
FIREBASE_PROJECT_ID=
FIREBASE_APP_ID=
# A service account JSON egy sorba szerializálva
FIREBASE_SERVICE_ACCOUNT=

# ----- AI (megrendelés-feldolgozás) -----
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ----- E-mail intake (opcionális — beérkező megrendelések IMAP-ból) -----
