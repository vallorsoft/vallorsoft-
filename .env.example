# ============================================================
#  VallorSoft — Környezeti változók sablon
#  Másold .env néven és töltsd ki a valódi értékekkel.
#  A valódi .env GITIGNORE-olt — soha ne commitold a titkokat!
# ============================================================

# ----- Alap -----
DATABASE_URL=postgres://user:password@host:5432/dbname
SESSION_SECRET=valami-hosszu-veletlen-titok
NODE_ENV=production
PORT=3000
APP_URL=https://example.com

# Integrációs kulcsok titkosításához (32 byte, hex vagy base64)
# Generálás: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTEGRATION_ENC_KEY=

# ----- Web Push (VAPID) -----
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@example.com

# ----- E-mail (Brevo) -----
BREVO_API_KEY=
BREVO_SENDER=noreply@example.com
MAIL_USER=noreply@example.com

# ----- Firebase -----
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_DB_URL=
FIREBASE_PROJECT_ID=
FIREBASE_APP_ID=
# A service account JSON egy sorba szerializálva
FIREBASE_SERVICE_ACCOUNT=

# ----- AI (megrendelés-feldolgozás) -----
# Általában elég csak a kulcs. A kiolvasó egy beépített MODELL-LÁNCON megy végig:
# 429 (napi kvóta/sebességkorlát) esetén automatikusan a következő modellre vált,
# mert minden modellnek KÜLÖN napi ingyenes kerete van.
# Alap lánc: gemini-2.0-flash -> -flash-lite -> 2.5-flash -> 2.5-flash-lite -> 1.5-flash -> 1.5-flash-8b
GEMINI_API_KEY=
# GEMINI_MODEL=...    # opcionális: EZ a modell kerül a lánc elejére (a többi marad tartaléknak)
# GEMINI_MODELS=m1,m2 # opcionális: a TELJES láncot felülírja (vesszős lista)

# ----- E-mail intake (opcionális — beérkező megrendelések IMAP-ból) -----
